---
import Layout from '../layouts/Layout.astro';
import teams from '../data/teams.json';
import groups from '../data/groups.json';
import matches from '../data/matches.json';
import matchEvents from '../data/match-events.json';
import { broadcastersFor } from '../lib/broadcasters';
import { fetchWorldCupMatches, normalizeTeam } from '../lib/football-data';

const now = new Date();
const TEAM_ELOS: Record<string, number> = {};
const TEAM_DATA: Record<string, any> = {};
for (const [key, val] of Object.entries(teams)) {
  TEAM_ELOS[key] = (val as any).elo;
  TEAM_DATA[key] = val;
}

function eloProb(eloA: number, eloB: number): number {
  return 1 / (1 + Math.pow(10, (eloB - eloA) / 400));
}

function getStatus(kickoffStr: string): 'final' | 'live' | 'upcoming' {
  const ko = new Date(kickoffStr);
  const end = new Date(ko.getTime() + 2.5 * 60 * 60 * 1000);
  if (now > end) return 'final';
  if (now >= ko) return 'live';
  return 'upcoming';
}

function toArgTime(kickoffStr: string): Date {
  return new Date(new Date(kickoffStr).getTime() - 3 * 60 * 60 * 1000);
}

function fmtDate(d: Date): string {
  const dd = String(d.getUTCDate()).padStart(2, '0');
  const mm = String(d.getUTCMonth() + 1).padStart(2, '0');
  const hh = String(d.getUTCHours()).padStart(2, '0');
  const min = String(d.getUTCMinutes()).padStart(2, '0');
  return `${dd}/${mm} ${hh}:${min}`;
}

const MONTHS = ['ENE','FEB','MAR','ABR','MAY','JUN','JUL','AGO','SEP','OCT','NOV','DIC'];

function fmtDateShort(d: Date): string {
  const dd = String(d.getUTCDate()).padStart(2, '0');
  const mm = MONTHS[d.getUTCMonth()];
  const hh = String(d.getUTCHours()).padStart(2, '0');
  const min = String(d.getUTCMinutes()).padStart(2, '0');
  return `${dd}/${mm} ${hh}:${min}`;
}

const STATUS_LABELS: Record<string, string> = {
  upcoming: 'Próximo',
  live: 'En juego',
  final: 'Final'
};

function groupMatches(groupTeams: string[]) {
  return matches.filter(m => groupTeams.includes(m.home) && groupTeams.includes(m.away));
}

function pct(v: number): string {
  return Math.round(v * 100) + '%';
}

function getEvents(home: string, away: string): any {
  const key1 = `${home}|${away}`;
  const key2 = `${away}|${home}`;
  return (matchEvents as any)[key1] || (matchEvents as any)[key2] || null;
}

// SSR: fetch match results from football-data.org so finished/live matches
// render with real scores on first paint (no "VS flash").
const SSR_SCORES_RAW: Record<string, { id: number; homeScore: number | null; awayScore: number | null; status: string }> = {};
try {
  const fdMatches = await fetchWorldCupMatches();
  for (const m of fdMatches) {
    const homeKey = normalizeTeam(m.homeTeam.name) ?? m.homeTeam.name;
    const awayKey = normalizeTeam(m.awayTeam.name) ?? m.awayTeam.name;
    SSR_SCORES_RAW[`${homeKey}|${awayKey}`] = {
      id: m.id,
      homeScore: m.score.fullTime.home,
      awayScore: m.score.fullTime.away,
      status: m.status,
    };
  }
} catch {
  // football-data.org unavailable — fall back to VS placeholders
}

function ssrScore(home: string, away: string): { id: number; homeScore: number | null; awayScore: number | null; status: string } | null {
  const direct = SSR_SCORES_RAW[`${home}|${away}`];
  if (direct) return direct;
  const reversed = SSR_SCORES_RAW[`${away}|${home}`];
  if (reversed) return { id: reversed.id, homeScore: reversed.awayScore, awayScore: reversed.homeScore, status: reversed.status };
  return null;
}

// Build SSR_SCORES keyed by our matches.json order so the client can iterate
// directly without re-mapping team directions.
const SSR_SCORES: Record<string, any> = {};
for (const m of matches as any[]) {
  const s = ssrScore(m.home, m.away);
  if (s) SSR_SCORES[`${m.home}|${m.away}`] = s;
}

const LIVE_API_STATUSES = ['LIVE', 'IN_PLAY', 'PAUSED'];

// ---- Knockout bracket: slot parsing & grouping ----

type SlotKind = 'winner' | 'runner-up' | 'loser' | 'group-pos' | 'third-place';

interface BracketSlotRef {
  kind: SlotKind;
  matchNum?: number;
  position?: number;
  group?: string;
  groups?: string[];
}

function parseSlot(raw: string): BracketSlotRef | null {
  if (!raw || typeof raw !== 'string') return null;
  let m: RegExpMatchArray | null;

  // W73 → winner of match 73
  m = raw.match(/^W(\d+)$/);
  if (m) return { kind: 'winner', matchNum: parseInt(m[1], 10) };

  // RU73 → runner-up of match 73
  m = raw.match(/^RU(\d+)$/);
  if (m) return { kind: 'runner-up', matchNum: parseInt(m[1], 10) };

  // L101 → loser of match 101
  m = raw.match(/^L(\d+)$/);
  if (m) return { kind: 'loser', matchNum: parseInt(m[1], 10) };

  // 3C/D/F/G/H → third-place from multiple groups
  m = raw.match(/^(\d)([A-L](?:\/[A-L])+)$/);
  if (m) return { kind: 'third-place', position: parseInt(m[1], 10), groups: m[2].split('/') };

  // 1A → group position
  m = raw.match(/^(\d)([A-L])$/);
  if (m) return { kind: 'group-pos', position: parseInt(m[1], 10), group: m[2] };

  return null;
}

function formatSlotLabel(raw: string): string {
  const slot = parseSlot(raw);
  if (!slot) return raw;

  switch (slot.kind) {
    case 'winner':
      return `Winner M${slot.matchNum}`;
    case 'runner-up':
      return `Runner-up M${slot.matchNum}`;
    case 'loser':
      return `Loser M${slot.matchNum}`;
    case 'group-pos': {
      const ordinals = ['', '1st', '2nd', '3rd'];
      const pos = slot.position || 1;
      return `${ordinals[pos] || pos + 'th'} Group ${slot.group}`;
    }
    case 'third-place':
      return `3rd Group ${(slot.groups || []).join('/')}`;
    default:
      return raw;
  }
}

const ROUND_ORDER: Record<string, number> = {
  'round-of-32': 0,
  'round-of-16': 1,
  'quarter-finals': 2,
  'semi-finals': 3,
  'third-place': 4,
  'final': 5,
};

const ROUND_DISPLAY: Record<string, string> = {
  'round-of-32': '16avos de final',
  'round-of-16': '8vos de final',
  'quarter-finals': 'Cuartos de final',
  'semi-finals': 'Semifinales',
  'third-place': '3er y 4to puesto',
  'final': 'Final',
};

function normalizeRound(round: string): string {
  const map: Record<string, string> = {
    'Round of 32': 'round-of-32',
    'Round of 16': 'round-of-16',
    'Quarter-finals': 'quarter-finals',
    'Semi-finals': 'semi-finals',
    'Third place': 'third-place',
    'Final': 'final',
  };
  return map[round] || round.toLowerCase().replace(/\s+/g, '-');
}

function knockoutBracket(allMatches: any[]): Map<string, any[]> {
  const knockout = allMatches
    .filter((m) => m.round)
    .map((m) => {
      // Synthesize num 103 for Third place, 104 for Final when missing
      if (m.num == null) {
        if (m.round === 'Third place') return { ...m, num: 103 };
        if (m.round === 'Final') return { ...m, num: 104 };
      }
      return m;
    });

  const grouped = new Map<string, any[]>();
  for (const m of knockout) {
    const key = normalizeRound(m.round);
    if (!grouped.has(key)) grouped.set(key, []);
    grouped.get(key)!.push(m);
  }

  // Sort each round's matches by num
  for (const matches of grouped.values()) {
    matches.sort((a, b) => (a.num || 999) - (b.num || 999));
  }

  // Sort rounds by ROUND_ORDER
  const sorted = new Map(
    [...grouped.entries()].sort((a, b) => {
      const orderA = ROUND_ORDER[a[0]] ?? 99;
      const orderB = ROUND_ORDER[b[0]] ?? 99;
      return orderA - orderB;
    })
  );

  return sorted;
}

// Pre-compute knockout bracket for SSR
const KO_BRACKET = knockoutBracket(matches as any[]);

---

<Layout>
  <header class="site">
    <h1>Mundial <span class="year">2026</span></h1>
    <p>Fixture de la fase de grupos · Resultados y predicción por Elo</p>
    <button class="live-flag" data-active="false" aria-expanded="false" id="liveToggle" type="button" style="cursor:pointer;background:none;font-family:inherit;color:inherit">
      <span class="dot"></span>
      <span class="live-flag__text">Sin partidos en juego</span>
      <span class="live-flag__chev">▾</span>
    </button>
    <div class="live-panel" id="livePanel" hidden></div>
  </header>

  <main class="groups">
    {groups.map((group: any) => {
      const gMatches = groupMatches(group.teams);
      return (
        <details class="group" open>
          <summary class="group__head">
            <h2>Grupo {group.id}</h2>
            <span class="group__chev">&#9660;</span>
          </summary>
          <ul class="group__teams">
            {group.teams.map((t: string) => (
              <li>
                <img
                  class="flag-img"
                  src={`https://flagcdn.com/w40/${TEAM_DATA[t].iso2}.png`}
                  alt={t}
                  loading="lazy"
                  width="22"
                  height="15"
                />
                {TEAM_DATA[t].nameEs}
              </li>
            ))}
          </ul>

          <details class="standings" data-group={group.id}>
            <summary class="standings__head">Tabla de posiciones</summary>
            <div class="standings__body">
              <p class="standings__hint">Tocá para cargar…</p>
            </div>
          </details>

          <div class="group__matches">
            {gMatches.map((m: any) => {
              const homeTeam = TEAM_DATA[m.home];
              const awayTeam = TEAM_DATA[m.away];
              const koStatus = getStatus(m.kickoff);
              const argTime = toArgTime(m.kickoff);
              const hElo = TEAM_ELOS[m.home];
              const aElo = TEAM_ELOS[m.away];
              const hProb = eloProb(hElo, aElo);
              const dProb = Math.max(0, 0.28 - Math.abs(hElo - aElo) / 1000);
              const aProb = eloProb(aElo, hElo);
              const total = hProb + dProb + aProb;
              const hPct = hProb / total;
              const dPct = dProb / total;
              const aPct = aProb / total;

              // SSR score injection: prefer football-data.org status when available
              const ssrScoreData = SSR_SCORES[`${m.home}|${m.away}`];
              const hasSSRScore = !!(ssrScoreData && ssrScoreData.homeScore !== null && ssrScoreData.awayScore !== null);
              const ssrStatus = ssrScoreData?.status;
              const isSSRLive = ssrStatus && LIVE_API_STATUSES.includes(ssrStatus);
              const isSSRFinished = ssrStatus === 'FINISHED';
              const status: 'final' | 'live' | 'upcoming' = ssrStatus
                ? (isSSRFinished ? 'final' : isSSRLive ? 'live' : 'upcoming')
                : koStatus;
              const live = status === 'live';

              return (
                <div
                  class={`match${status === 'upcoming' ? ' match--upcoming' : ''}${live ? ' match--live' : ''}`}
                  data-home={m.home}
                  data-away={m.away}
                  data-kickoff={m.kickoff}
                  data-match-id={ssrScoreData?.id ? String(ssrScoreData.id) : undefined}
                  data-ssr-status={ssrStatus ?? undefined}
                >
                  <div class="teams">
                    <div class="team team--home">
                      <img
                        class="flag-img"
                        src={`https://flagcdn.com/w40/${homeTeam.iso2}.png`}
                        alt={m.home}
                        loading="lazy"
                        width="34"
                        height="23"
                      />
                      <span class="name">{homeTeam.nameEs}</span>
                    </div>
                    <div class={`score${hasSSRScore ? ' score--has' : ''}${isSSRFinished ? ' score--clickable' : ''}`}>
                      {hasSSRScore ? (
                        <>
                          <span class="vs">{ssrScoreData.homeScore}</span>
                          <span class="vs-div">-</span>
                          <span class="vs">{ssrScoreData.awayScore}</span>
                          {live && <span class="live-dot score__live-dot"></span>}
                        </>
                      ) : (
                        <span class="vs">VS</span>
                      )}
                    </div>
                    <div class="team team--away">
                      <img
                        class="flag-img"
                        src={`https://flagcdn.com/w40/${awayTeam.iso2}.png`}
                        alt={m.away}
                        loading="lazy"
                        width="34"
                        height="23"
                      />
                      <span class="name">{awayTeam.nameEs}</span>
                    </div>
                  </div>
                  <div class="meta">
                    <span>{fmtDateShort(argTime)}</span>
                    <span class={`status${live ? ' live' : status === 'final' ? ' final' : ''}`} data-state={status}>
                      {live && <span class="live-dot"></span>}
                      {STATUS_LABELS[status]}
                    </span>
                  </div>
                  <div class="pred">
                    <div class="pred__label">Predicción Elo</div>
                    <div class="bar">
                      <div class="seg--1" style={`width:${pct(hPct)}`}></div>
                      <div class="seg--d" style={`width:${pct(dPct)}`}></div>
                      <div class="seg--2" style={`width:${pct(aPct)}`}></div>
                    </div>
                    <div class="pct">
                      <span>{pct(hPct)}</span>
                      <span>{pct(dPct)}</span>
                      <span>{pct(aPct)}</span>
                    </div>
                  </div>
                  {
                    (() => {
                      const bcs = broadcastersFor(m.home, m.away);
                      if (!bcs.length) return null;
                      const confirmed = bcs.filter(b => b.confirmed);
                      const tentative = bcs.filter(b => !b.confirmed);
                      return (
                        <div class="broadcasters">
                          <span class="broadcasters__label">TV:</span>
                          {confirmed.map(b => (
                            <span class="badge badge--confirmed" title={b.name}>{b.shortName}</span>
                          ))}
                          {tentative.map(b => (
                            <span class="badge badge--tentative" title={`${b.name} (a confirmar)`}>
                              {b.shortName}
                              <span class="badge__note">a confirmar</span>
                            </span>
                          ))}
                        </div>
                      );
                    })()
                  }
                  {
                    (() => {
                      const st = getStatus(m.kickoff);
                      if (st !== 'final') return null;
                      const evts = getEvents(m.home, m.away);
                      if (!evts) return null;
                      return (
                        <div class="match-events">
                          {evts.goals && evts.goals.length > 0 && (
                            <div class="match-events__section">
                              <h4 class="match-events__title">⚽ Goles</h4>
                              {evts.goals.map((g: any) => (
                                <div class="match-events__row">
                                  <span class="match-events__minute">{g.minute}'</span>
                                  <span class="match-events__icon">{g.type === 'PENALTY' ? '🥅' : g.type === 'OWN_GOAL' ? '💀' : '⚽'}</span>
                                  <span class="match-events__player">{g.player}</span>
                                </div>
                              ))}
                            </div>
                          )}
                          {evts.cards && evts.cards.length > 0 && (
                            <div class="match-events__section">
                              <h4 class="match-events__title">🟨🟥 Tarjetas</h4>
                              {evts.cards.map((c: any) => (
                                <div class="match-events__row">
                                  <span class="match-events__minute">{c.minute}'</span>
                                  <span class="match-events__icon">{c.card === 'RED' ? '🟥' : '🟨'}</span>
                                  <span class="match-events__player">{c.player}</span>
                                </div>
                              ))}
                            </div>
                          )}
                          {evts.mvp && (
                            <div class="match-events__section">
                              <h4 class="match-events__title">⭐ MVP</h4>
                              <p class="match-events__mvp">{evts.mvp}</p>
                            </div>
                          )}
                        </div>
                      );
                    })()
                  }
                </div>
              );
            })}
          </div>
        </details>
      );
    })}
  </main>

  <section class="bracket">
    {[...KO_BRACKET].map(([roundKey, roundMatches]) => (
      <div class="bracket__round">
        <h2 class="bracket__round-title">{ROUND_DISPLAY[roundKey]}</h2>
        {roundMatches.map((m: any) => {
          const homeResolved = TEAM_DATA[m.home];
          const awayResolved = TEAM_DATA[m.away];
          const isUnresolved = !homeResolved || !awayResolved;
          const koStatus = getStatus(m.kickoff);
          const argTime = toArgTime(m.kickoff);
          const live = koStatus === 'live';
          const koScoreData = SSR_SCORES[`${m.home}|${m.away}`];
          const koHasScore = !!(koScoreData && koScoreData.homeScore !== null && koScoreData.awayScore !== null);
          const koIsFinished = koScoreData?.status === 'FINISHED' || koStatus === 'final';

          return (
            <div
              class={`match match--knockout${isUnresolved ? ' match--unresolved' : ''}${koStatus === 'upcoming' ? ' match--upcoming' : ''}${live ? ' match--live' : ''}`}
              data-home={m.home}
              data-away={m.away}
              data-kickoff={m.kickoff}
              data-match-id={koScoreData?.id ? String(koScoreData.id) : undefined}
              data-ssr-status={koScoreData?.status ?? undefined}
            >
              <div class="teams">
                <div class={`team team--home${!homeResolved ? ' team--unresolved' : ''}`}>
                  <img
                    class="flag-img"
                    src={homeResolved ? `https://flagcdn.com/w40/${homeResolved.iso2}.png` : 'data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7'}
                    alt={homeResolved ? homeResolved.nameEs : m.home}
                    loading="lazy"
                    width="34"
                    height="23"
                  />
                  <span class="name">{homeResolved ? homeResolved.nameEs : formatSlotLabel(m.home)}</span>
                </div>
                <div class={`score${koHasScore ? ' score--has' : ''}${koIsFinished ? ' score--clickable' : ''}`}>
                  {koHasScore ? (
                    <>
                      <span class="vs">{koScoreData.homeScore}</span>
                      <span class="vs-div">-</span>
                      <span class="vs">{koScoreData.awayScore}</span>
                      {live && <span class="live-dot score__live-dot"></span>}
                    </>
                  ) : (
                    <span class="vs">VS</span>
                  )}
                </div>
                <div class={`team team--away${!awayResolved ? ' team--unresolved' : ''}`}>
                  <img
                    class="flag-img"
                    src={awayResolved ? `https://flagcdn.com/w40/${awayResolved.iso2}.png` : 'data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7'}
                    alt={awayResolved ? awayResolved.nameEs : m.away}
                    loading="lazy"
                    width="34"
                    height="23"
                  />
                  <span class="name">{awayResolved ? awayResolved.nameEs : formatSlotLabel(m.away)}</span>
                </div>
              </div>
              <div class="meta">
                <span>{fmtDateShort(argTime)}</span>
                <span class={`status${live ? ' live' : koStatus === 'final' ? ' final' : ''}`} data-state={koStatus}>
                  {live && <span class="live-dot"></span>}
                  {STATUS_LABELS[koStatus]}
                </span>
              </div>
              {koStatus === 'final' && (() => {
                const evts = getEvents(m.home, m.away);
                const hasEvents = evts && ((evts.goals && evts.goals.length > 0) || (evts.cards && evts.cards.length > 0) || evts.mvp);
                return (
                  <>
                    <button class="match-events-toggle" type="button" aria-expanded={hasEvents ? 'true' : 'false'}>
                      <span class="match-events-toggle__icon">&#9660;</span>
                      <span class="match-events-toggle__label">Detalles del partido</span>
                    </button>
                    <div class={`match-events${hasEvents ? ' match-events--open' : ''}`}>
                      {evts?.goals && evts.goals.length > 0 && (
                        <div class="match-events__section">
                          <h4 class="match-events__title">⚽ Goles</h4>
                          {evts.goals.map((g: any) => (
                            <div class="match-events__row">
                              <span class="match-events__minute">{g.minute}'</span>
                              <span class="match-events__icon">{g.type === 'PENALTY' ? '🥅' : g.type === 'OWN_GOAL' ? '💀' : '⚽'}</span>
                              <span class="match-events__player">{g.player}</span>
                            </div>
                          ))}
                        </div>
                      )}
                      {evts?.cards && evts.cards.length > 0 && (
                        <div class="match-events__section">
                          <h4 class="match-events__title">🟨🟥 Tarjetas</h4>
                          {evts.cards.map((c: any) => (
                            <div class="match-events__row">
                              <span class="match-events__minute">{c.minute}'</span>
                              <span class="match-events__icon">{c.card === 'RED' ? '🟥' : '🟨'}</span>
                              <span class="match-events__player">{c.player}</span>
                            </div>
                          ))}
                        </div>
                      )}
                      {evts?.mvp && (
                        <div class="match-events__section">
                          <h4 class="match-events__title">⭐ MVP</h4>
                          <p class="match-events__mvp">{evts.mvp}</p>
                        </div>
                      )}
                      {!hasEvents && (
                        <p class="match-events__empty">Los detalles aparecerán aquí cuando estén disponibles.</p>
                      )}
                    </div>
                  </>
                );
              })()}
            </div>
          );
        })}
      </div>
    ))}
  </section>

  <div class="vs-modal" data-vs-modal hidden>
    <div class="vs-overlay"></div>
    <div class="vs-stage">
      <button class="vs-x" aria-label="Cerrar">&times;</button>
      <div class="vs-side vs-side--left">
        <img class="vs-flag" src="" alt="" data-vs-flag-left />
        <h3 class="vs-country" data-vs-country-left></h3>
        <p class="vs-player" data-vs-player-left></p>
        <div class="vs-events" data-vs-events-left></div>
        <div class="vs-prob"><span data-vs-prob-left></span> <small>probabilidad</small></div>
      </div>
      <div class="vs-center">
        <div class="vs-score" data-vs-score></div>
        <div class="vs-badge">VS</div>
      </div>
      <div class="vs-side vs-side--right">
        <img class="vs-flag" src="" alt="" data-vs-flag-right />
        <h3 class="vs-country" data-vs-country-right></h3>
        <p class="vs-player" data-vs-player-right></p>
        <div class="vs-events" data-vs-events-right></div>
        <div class="vs-prob"><span data-vs-prob-right></span> <small>probabilidad</small></div>
      </div>
    </div>
  </div>

  <template id="match-detail-tpl">
    <div class="match-detail">
      <div class="match-detail__goals">
        <h4 class="match-detail__title">⚽ Goles</h4>
        <div class="match-detail__list" data-detail-goals></div>
      </div>
      <div class="match-detail__cards">
        <h4 class="match-detail__title">🟨🟥 Tarjetas</h4>
        <div class="match-detail__list" data-detail-cards></div>
      </div>
      <div class="match-detail__mvp">
        <h4 class="match-detail__title">⭐ MVP</h4>
        <p class="match-detail__mvp-player" data-detail-mvp></p>
      </div>
    </div>
  </template>

  <footer class="site-footer">
    Datos de fixture: <a href="https://github.com/openfootball">openfootball</a>,{' '}
    <a href="https://football-data.org">football-data.org</a>,{' '}
    <a href="https://www.eloratings.net">World Football Elo</a>
    &mdash; Datos en vivo vía football-data.org.
  </footer>

  <script set:html={`window.__VS_DATA__ = ${JSON.stringify(TEAM_DATA)};
window.__EVENTS_DATA__ = ${JSON.stringify(matchEvents)};
window.__SSR_SCORES__ = ${JSON.stringify(SSR_SCORES)};
window.__KNOCKOUT__ = ${JSON.stringify(Object.fromEntries(KO_BRACKET))};`}></script>

  <script>
    const vsData = (window as any).__VS_DATA__ || {};
    const eventsData = (window as any).__EVENTS_DATA__ || {};
    const vsModal = document.querySelector('[data-vs-modal]') as HTMLElement | null;
    const vsOverlay = vsModal?.querySelector('.vs-overlay') as HTMLElement | null;
    const vsX = vsModal?.querySelector('.vs-x') as HTMLElement | null;

    function eloProb(eloA: number, eloB: number): number {
      return 1 / (1 + Math.pow(10, (eloB - eloA) / 400));
    }

    function getEventsData(home: string, away: string): any {
      const key1 = `${home}|${away}`;
      const key2 = `${away}|${home}`;
      return eventsData[key1] || eventsData[key2] || null;
    }

    function openModal(home: string, away: string) {
      if (!vsModal) return;
      const h = (vsData as any)[home];
      const a = (vsData as any)[away];
      if (!h || !a) return;

      const leftFlag = vsModal.querySelector('[data-vs-flag-left]') as HTMLImageElement;
      const rightFlag = vsModal.querySelector('[data-vs-flag-right]') as HTMLImageElement;
      const leftCountry = vsModal.querySelector('[data-vs-country-left]') as HTMLElement;
      const rightCountry = vsModal.querySelector('[data-vs-country-right]') as HTMLElement;
      const leftPlayer = vsModal.querySelector('[data-vs-player-left]') as HTMLElement;
      const rightPlayer = vsModal.querySelector('[data-vs-player-right]') as HTMLElement;
      const leftProb = vsModal.querySelector('[data-vs-prob-left]') as HTMLElement;
      const rightProb = vsModal.querySelector('[data-vs-prob-right]') as HTMLElement;
      const scoreEl = vsModal.querySelector('[data-vs-score]') as HTMLElement;
      const leftEvents = vsModal.querySelector('[data-vs-events-left]') as HTMLElement;
      const rightEvents = vsModal.querySelector('[data-vs-events-right]') as HTMLElement;

      if (leftFlag) leftFlag.src = `https://flagcdn.com/w160/${h.iso2}.png`;
      if (rightFlag) rightFlag.src = `https://flagcdn.com/w160/${a.iso2}.png`;
      if (leftCountry) leftCountry.textContent = h.nameEs;
      if (rightCountry) rightCountry.textContent = a.nameEs;
      if (leftPlayer) leftPlayer.innerHTML = `<small>Figura</small>${h.player}`;
      if (rightPlayer) rightPlayer.innerHTML = `<small>Figura</small>${a.player}`;

      const hProb = eloProb(h.elo, a.elo);
      const aProb = eloProb(a.elo, h.elo);
      if (leftProb) leftProb.textContent = Math.round(hProb * 100) + '%';
      if (rightProb) rightProb.textContent = Math.round(aProb * 100) + '%';

      // Score: try to read from the match card DOM
      const matchEl = document.querySelector(`.match[data-home="${home}"][data-away="${away}"]`) as HTMLElement | null;
      if (scoreEl && matchEl) {
        const scoreSpan = matchEl.querySelector('.score--has');
        if (scoreSpan) {
          scoreEl.innerHTML = scoreSpan.innerHTML.replace(/VS/g, '').replace(/vs/g, '');
          scoreEl.classList.add('vs-score--has');
        } else {
          scoreEl.innerHTML = '';
          scoreEl.classList.remove('vs-score--has');
        }
      }

      // Events: goals and cards from local data
      const evts = getEventsData(home, away);
      if (leftEvents) leftEvents.innerHTML = '';
      if (rightEvents) rightEvents.innerHTML = '';

      if (evts) {
        const evtClass = 'vs-event';
        if (evts.goals && leftEvents && rightEvents) {
          for (const g of evts.goals) {
            const icon = g.type === 'PENALTY' ? '🥅' : g.type === 'OWN_GOAL' ? '💀' : '⚽';
            const html = `<div class="${evtClass}"><span>${icon}</span> ${g.player}</div>`;
            if (g.team === home) leftEvents.innerHTML += html;
            else if (g.team === away) rightEvents.innerHTML += html;
          }
        }
        if (evts.cards && leftEvents && rightEvents) {
          for (const c of evts.cards) {
            const icon = c.card === 'RED' ? '🟥' : '🟨';
            const html = `<div class="${evtClass}"><span>${icon}</span> ${c.player}</div>`;
            if (c.team === home) leftEvents.innerHTML += html;
            else if (c.team === away) rightEvents.innerHTML += html;
          }
        }
      }

      vsModal.hidden = false;
      requestAnimationFrame(() => {
        vsModal.classList.add('is-open');
      });
    }

    function closeModal() {
      if (!vsModal) return;
      vsModal.classList.remove('is-open');
      setTimeout(() => {
        vsModal.hidden = true;
      }, 400);
    }

    document.querySelectorAll('.match').forEach(el => {
      el.addEventListener('click', () => {
        const home = el.getAttribute('data-home');
        const away = el.getAttribute('data-away');
        if (home && away) openModal(home, away);
      });
    });

    vsOverlay?.addEventListener('click', closeModal);
    vsX?.addEventListener('click', closeModal);
    vsModal?.addEventListener('click', (e) => {
      if (e.target === vsModal) closeModal();
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && vsModal && !vsModal.hidden) closeModal();
    });
  </script>

  <script is:inline>
    // ---- Live polling & standings lazy-load ----
    const LIVE_POLL_MS = 20_000;
    const DETAIL_REFRESH_MS = 30_000;
    const UPCOMING_WINDOW_H = 36;

    const liveFlag = document.getElementById('liveToggle');
    const livePanel = document.getElementById('livePanel');
    const liveFlagText = liveFlag?.querySelector('.live-flag__text');

    function updateLiveFlag(liveCount, liveMatches) {
      if (!liveFlag || !liveFlagText) return;
      const dot = liveFlag.querySelector('.dot');
      const chev = liveFlag.querySelector('.live-flag__chev');

      if (liveCount > 0) {
        liveFlag.setAttribute('data-active', 'true');
        const word = liveCount === 1 ? 'partido' : 'partidos';
        liveFlagText.textContent = `${liveCount} ${word} en juego`;
        if (dot) dot.classList.add('live');
        if (chev) chev.style.display = 'inline';
        // Auto-expand panel
        liveFlag.setAttribute('aria-expanded', 'true');
        if (livePanel) livePanel.hidden = false;
      } else {
        liveFlag.setAttribute('data-active', 'false');
        liveFlagText.textContent = 'Sin partidos en juego';
        if (dot) dot.classList.remove('live');
        if (chev) chev.style.display = 'none';
        liveFlag.setAttribute('aria-expanded', 'false');
        if (livePanel) livePanel.hidden = true;
      }
    }

    function populateLivePanel(liveMatches) {
      if (!livePanel) return;
      if (!liveMatches.length) {
        livePanel.innerHTML = '';
        return;
      }

      let html = '';
      for (const m of liveMatches) {
        const home = m.home || '?';
        const away = m.away || '?';
        const hScore = m.homeScore ?? '-';
        const aScore = m.awayScore ?? '-';
        html += `<div class="live-match-pill" data-home="${home}" data-away="${away}">
          <span class="live-match-pill__teams">${home} <strong>${hScore} - ${aScore}</strong> ${away}</span>
          <span class="live-match-pill__status live-dot"></span>
        </div>`;
      }
      livePanel.innerHTML = html;
    }

    // Toggle panel on button click
    liveFlag?.addEventListener('click', () => {
      if (!livePanel) return;
      const expanded = liveFlag.getAttribute('aria-expanded') === 'true';
      liveFlag.setAttribute('aria-expanded', String(!expanded));
      livePanel.hidden = expanded;
    });

    // Click live match pill → scroll to match card
    livePanel?.addEventListener('click', (e) => {
      const pill = e.target.closest('.live-match-pill');
      if (!pill) return;
      const home = pill.getAttribute('data-home');
      const away = pill.getAttribute('data-away');
      if (!home || !away) return;
      const matchEl = findMatchEl(home, away);
      if (matchEl) {
        matchEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
        matchEl.style.transition = 'box-shadow .4s';
        matchEl.style.boxShadow = '0 0 0 4px var(--red)';
        setTimeout(() => { matchEl.style.boxShadow = ''; }, 2000);
      }
    });

    function findMatchEl(home, away) {
      const all = document.querySelectorAll('.match');
      for (const el of all) {
        if (el.getAttribute('data-home') === home && el.getAttribute('data-away') === away) {
          return el;
        }
      }
      return null;
    }

    function updateMatchScore(matchId, home, away, hScore, aScore, status, matchEl) {
      if (!matchEl) {
        matchEl = findMatchEl(home, away);
      }
      if (!matchEl) return;

      // Store match ID for detail lookup
      matchEl.setAttribute('data-match-id', String(matchId));
      if (status) matchEl.setAttribute('data-ssr-status', status);

      // Resolve team names + flags for knockout cards (slot labels → real teams)
      const teamData = window.__VS_DATA__ || {};
      if (matchEl.classList.contains('match--knockout')) {
        const homeName = matchEl.querySelector('.team--home .name');
        const awayName = matchEl.querySelector('.team--away .name');
        const homeFlag = matchEl.querySelector('.team--home .flag-img');
        const awayFlag = matchEl.querySelector('.team--away .flag-img');

        if (homeName && teamData[home]) {
          homeName.textContent = teamData[home].nameEs || home;
          matchEl.querySelector('.team--home')?.classList.remove('team--unresolved');
          if (homeFlag) {
            homeFlag.src = `https://flagcdn.com/w40/${teamData[home].iso2}.png`;
            homeFlag.alt = teamData[home].nameEs || home;
          }
        }
        if (awayName && teamData[away]) {
          awayName.textContent = teamData[away].nameEs || away;
          matchEl.querySelector('.team--away')?.classList.remove('team--unresolved');
          if (awayFlag) {
            awayFlag.src = `https://flagcdn.com/w40/${teamData[away].iso2}.png`;
            awayFlag.alt = teamData[away].nameEs || away;
          }
        }
        // Remove unresolved state if both teams are now known
        if (teamData[home] && teamData[away]) {
          matchEl.classList.remove('match--unresolved');
        }
      }

      // Update score display
      const scoreEl = matchEl.querySelector('.score');
      if (scoreEl && hScore !== null && aScore !== null) {
        scoreEl.innerHTML = `<span class="vs">${hScore}</span> <span class="vs-div">-</span> <span class="vs">${aScore}</span>`;
        scoreEl.classList.add('score--has');
      }

      // Update status badge
      const statusEl = matchEl.querySelector('.status');
      if (statusEl) {
        const isLive = status === 'LIVE' || status === 'IN_PLAY' || status === 'PAUSED';
        const isFinished = status === 'FINISHED';

        // Remove old state classes
        matchEl.classList.remove('match--live', 'match--upcoming');

        if (isLive) {
          matchEl.classList.add('match--live');
          statusEl.className = 'status live';
          statusEl.setAttribute('data-state', 'live');
          statusEl.innerHTML = '<span class="live-dot"></span> En juego';
          // Make score clickable for live detail too
          if (scoreEl) {
            scoreEl.classList.add('score--clickable');
            scoreEl.style.cursor = 'pointer';
            scoreEl.title = 'Click para ver detalles';
          }
        } else if (isFinished) {
          statusEl.className = 'status final';
          statusEl.setAttribute('data-state', 'final');
          statusEl.textContent = 'Final';
          // Enable click for details
          if (scoreEl) {
            scoreEl.classList.add('score--clickable');
            scoreEl.style.cursor = 'pointer';
            scoreEl.title = 'Click para ver detalles';
          }
          // Stop auto-refreshing this match's detail panel — it's done
          if (activeDetailMatchId === String(matchId)) {
            clearDetailRefresh();
          }
        }
      }
    }

    // ---- SSR score injection (instant first paint) ----
    function processSSRScores() {
      const ssrScores = window.__SSR_SCORES__ || {};
      for (const key of Object.keys(ssrScores)) {
        const [home, away] = key.split('|');
        const s = ssrScores[key];
        if (s.homeScore === null || s.awayScore === null) continue;
        updateMatchScore(s.id, home, away, s.homeScore, s.awayScore, s.status);
      }
    }

    // ---- Match detail panel auto-refresh (live matches only) ----
    let detailRefreshInterval = null;
    let activeDetailMatchId = null;

    function clearDetailRefresh() {
      if (detailRefreshInterval) {
        clearInterval(detailRefreshInterval);
        detailRefreshInterval = null;
      }
      activeDetailMatchId = null;
    }

    function setupDetailRefresh(matchEl, matchId) {
      // Always clear any prior interval — only one detail panel auto-refreshes at a time
      clearDetailRefresh();
      const ssrStatus = matchEl.getAttribute('data-ssr-status');
      const isLive = ssrStatus && (ssrStatus === 'LIVE' || ssrStatus === 'IN_PLAY' || ssrStatus === 'PAUSED')
        || matchEl.classList.contains('match--live');
      if (!isLive) return;
      activeDetailMatchId = String(matchId);
      detailRefreshInterval = setInterval(() => refreshDetailPanel(matchEl), DETAIL_REFRESH_MS);
    }

    async function refreshDetailPanel(matchEl) {
      const matchId = matchEl.getAttribute('data-match-id');
      if (!matchId || activeDetailMatchId !== String(matchId)) return;
      // If the panel was closed, stop refreshing
      const detailEl = matchEl.querySelector('.match-detail.is-open');
      if (!detailEl) { clearDetailRefresh(); return; }
      try {
        const res = await fetch(`/api/match/${matchId}`);
        if (!res.ok) return;
        const d = await res.json();
        const home = matchEl.getAttribute('data-home');
        const away = matchEl.getAttribute('data-away');
        // Sync the score + status badge on the card
        if (d.homeScore !== null && d.awayScore !== null) {
          updateMatchScore(d.id, home, away, d.homeScore, d.awayScore, d.status);
        }
        if (d.status === 'FINISHED') {
          clearDetailRefresh();
          return;
        }
        renderDetailContent(detailEl, d, matchEl);
      } catch (_) {
        // Ignore transient network errors — interval will retry
      }
    }

    function renderDetailContent(detailEl, d, matchEl) {
      const goalsList = detailEl.querySelector('[data-detail-goals]');
      const cardsList = detailEl.querySelector('[data-detail-cards]');
      const mvpEl = detailEl.querySelector('[data-detail-mvp]');

      if (goalsList) {
        if (d.goals && d.goals.length > 0) {
          goalsList.innerHTML = d.goals.map((g) => {
            const icon = g.type === 'PENALTY' ? '🥅' : g.type === 'OWN_GOAL' ? '💀' : '⚽';
            const scorer = g.scorer || 'Desconocido';
            const assist = g.assist ? ` <span class="match-detail__assist">(asist. ${g.assist})</span>` : '';
            const min = g.injuryTime ? `${g.minute}+${g.injuryTime}'` : `${g.minute}'`;
            return `<div class="match-detail__row">
              <span class="match-detail__minute">${min}</span>
              <span class="match-detail__icon">${icon}</span>
              <span class="match-detail__player">${scorer}</span>${assist}
            </div>`;
          }).join('');
        } else {
          goalsList.innerHTML = '<span style="color:var(--muted)">Sin datos de goles</span>';
        }
      }

      if (cardsList) {
        if (d.bookings && d.bookings.length > 0) {
          cardsList.innerHTML = d.bookings.map((b) => {
            const icon = b.card === 'RED' ? '🟥' : '🟨';
            return `<div class="match-detail__row">
              <span class="match-detail__minute">${b.minute}'</span>
              <span class="match-detail__icon">${icon}</span>
              <span class="match-detail__player">${b.player}</span>
            </div>`;
          }).join('');
        } else {
          cardsList.innerHTML = '<span style="color:var(--muted)">Sin tarjetas</span>';
        }
      }

      if (mvpEl) {
        if (d.mvp) {
          mvpEl.textContent = d.mvp;
        } else {
          const teamData = window.__VS_DATA__ || {};
          const homeTeam = matchEl.getAttribute('data-home') || '';
          const awayTeam = matchEl.getAttribute('data-away') || '';
          const hScore = parseInt(matchEl.querySelector('.score--has .vs')?.textContent || '0') || 0;
          const aScore = parseInt(matchEl.querySelector('.score--has .vs:last-child')?.textContent || '0') || 0;
          const winner = getWinnerTeam(homeTeam, awayTeam, hScore, aScore);
          if (winner && teamData[winner]) {
            mvpEl.textContent = `${teamData[winner].player} (${teamData[winner].nameEs || winner})`;
          } else {
            mvpEl.textContent = 'Sin definir (empate)';
          }
        }
      }
    }

    function getClientLiveMatches() {
      const now = new Date();
      const liveMatches = [];
      const seen = new Set();
      document.querySelectorAll('.match').forEach((el) => {
        const home = el.getAttribute('data-home');
        const away = el.getAttribute('data-away');
        const kickoff = el.getAttribute('data-kickoff');
        if (!home || !away || !kickoff) return;
        const ko = new Date(kickoff);
        const end = new Date(ko.getTime() + 2.5 * 60 * 60 * 1000);
        if (now >= ko && now <= end) {
          const key = `${home}|${away}`;
          if (!seen.has(key)) {
            seen.add(key);
            // Try to get scores from the DOM if already updated
            const scoreEl = el.querySelector('.score--has .vs');
            liveMatches.push({
              id: 0,
              home,
              away,
              homeScore: null,
              awayScore: null,
              status: 'LIVE',
              kickoff: kickoff,
            });
          }
        }
      });
      return liveMatches;
    }

    function resolveByKickoff(kickoff, kickoffMap) {
      if (!kickoff) return null;
      // Exact ISO match
      const el = kickoffMap.get(kickoff);
      if (el) return el;
      // Minute-prefix fallback handles second-level drift
      const prefix = kickoff.slice(0, 16);
      for (const [key, val] of kickoffMap) {
        if (key.slice(0, 16) === prefix) return val;
      }
      return null;
    }

    function updateMatchEvents(matchEl, events) {
      if (!matchEl || !events) return

      const isKnockout = matchEl.classList.contains('match--knockout')

      // Find or create the .match-events container
      let eventsEl = matchEl.querySelector('.match-events')
      if (!eventsEl) {
        eventsEl = document.createElement('div')
        eventsEl.className = 'match-events'
        matchEl.appendChild(eventsEl)
      }

      let html = ''

      // Goals section
      if (events.goals && events.goals.length > 0) {
        html += '<div class="match-events__section">'
        html += '<h4 class="match-events__title">⚽ Goles</h4>'
        for (const g of events.goals) {
          const icon = g.type === 'PENALTY' ? '🥅' : g.type === 'OWN_GOAL' ? '💀' : '⚽'
          const min = g.injuryTime ? `${g.minute}+${g.injuryTime}'` : `${g.minute}'`
          const scorer = g.scorer || 'Desconocido'
          const assist = g.assist ? ` <span class="match-events__assist">(asist. ${g.assist})</span>` : ''
          html += `<div class="match-events__row">`
          html += `<span class="match-events__minute">${min}</span>`
          html += `<span class="match-events__icon">${icon}</span>`
          html += `<span class="match-events__player">${scorer}</span>${assist}`
          html += `</div>`
        }
        html += '</div>'
      }

      // Bookings section
      if (events.bookings && events.bookings.length > 0) {
        html += '<div class="match-events__section">'
        html += '<h4 class="match-events__title">🟨🟥 Tarjetas</h4>'
        for (const b of events.bookings) {
          const icon = b.card === 'RED' ? '🟥' : '🟨'
          html += `<div class="match-events__row">`
          html += `<span class="match-events__minute">${b.minute}'</span>`
          html += `<span class="match-events__icon">${icon}</span>`
          html += `<span class="match-events__player">${b.player || 'Desconocido'}</span>`
          html += `</div>`
        }
        html += '</div>'
      }

      // MVP section
      if (events.mvp) {
        html += '<div class="match-events__section">'
        html += '<h4 class="match-events__title">⭐ MVP</h4>'
        html += `<p class="match-events__mvp">${events.mvp}</p>`
        html += '</div>'
      }

      eventsEl.innerHTML = html

      // For knockout cards: auto-open toggle + show events section
      if (isKnockout) {
        eventsEl.classList.add('match-events--open')
        const toggle = matchEl.querySelector('.match-events-toggle')
        if (toggle) {
          toggle.classList.add('match-events-toggle--open')
          toggle.setAttribute('aria-expanded', 'true')
        }
      }
    }

    // ---- Knockout match-events toggle ----
    document.addEventListener('click', (e) => {
      const toggle = e.target.closest('.match-events-toggle')
      if (!toggle) return
      const matchEl = toggle.closest('.match')
      const eventsEl = matchEl?.querySelector('.match-events')
      if (!eventsEl) return
      const isOpen = eventsEl.classList.toggle('match-events--open')
      toggle.classList.toggle('match-events-toggle--open', isOpen)
      toggle.setAttribute('aria-expanded', String(isOpen))
    })

    async function pollLive() {
      try {
        const res = await fetch('/api/live');
        if (!res.ok) return;
        const data = await res.json();

        const apiLive = data.live || [];
        // Fallback: also check client-side for matches that are live by kickoff time
        const clientLive = apiLive.length === 0 ? getClientLiveMatches() : [];
        const liveMatches = apiLive.length > 0 ? apiLive : clientLive;

        // Update live flag + panel
        updateLiveFlag(liveMatches.length, liveMatches);
        populateLivePanel(liveMatches);

        // Build kickoff→element map for knockout timestamp join
        const kickoffMap = new Map();
        document.querySelectorAll('.match[data-kickoff]').forEach((el) => {
          const ko = el.getAttribute('data-kickoff');
          if (ko && ko.trim()) kickoffMap.set(ko, el);
        });

        // Update finished matches (show scores)
        const finished = data.finished || [];
        for (const m of finished) {
          const matchEl = resolveByKickoff(m.kickoff, kickoffMap);
          updateMatchScore(m.id, m.home, m.away, m.homeScore, m.awayScore, m.status, matchEl);
          if (matchEl && m.events) {
            updateMatchEvents(matchEl, m.events)
          }
        }

        // Update live matches
        for (const m of liveMatches) {
          const matchEl = resolveByKickoff(m.kickoff, kickoffMap);
          updateMatchScore(m.id, m.home, m.away, m.homeScore, m.awayScore, m.status, matchEl);
          if (matchEl && m.events) {
            updateMatchEvents(matchEl, m.events)
          }
        }
      } catch (_) {
        // Silently ignore network errors
      }
    }

    // ---- Standings lazy-load ----
    const loadedStandings = new Set();

    async function loadStandings(groupEl) {
      const groupId = groupEl.getAttribute('data-group');
      if (!groupId || loadedStandings.has(groupId)) return;

      const body = groupEl.querySelector('.standings__body');
      if (!body) return;

      // Get team name translations
      const teamData = window.__VS_DATA__ || {};
      const teamNames = {};
      if (teamData) {
        for (const [key, val] of Object.entries(teamData)) {
          teamNames[key] = val.nameEs || key;
        }
      }

      // Show loading
      body.innerHTML = '<p style="text-align:center;color:var(--muted);padding:1rem;">Cargando…</p>';

      try {
        const res = await fetch('/api/standings');
        if (!res.ok) throw new Error('API error');
        const data = await res.json();
        const groupData = data.groups?.[groupId];

        if (!groupData || !groupData.length) {
          body.innerHTML = '<p style="text-align:center;color:var(--muted);padding:1rem;">Sin datos todavía</p>';
          return;
        }

        let html = '<table class="standings-table"><thead><tr><th>#</th><th>Equipo</th><th>PJ</th><th>G</th><th>E</th><th>P</th><th>GF</th><th>GC</th><th>DG</th><th>Pts</th></tr></thead><tbody>';

        for (const row of groupData) {
          const displayName = teamNames[row.team] || row.team;
          html += `<tr>
            <td>${row.pos}</td>
            <td class="standings-team">${displayName}</td>
            <td>${row.p}</td>
            <td>${row.w}</td>
            <td>${row.d}</td>
            <td>${row.l}</td>
            <td>${row.gf}</td>
            <td>${row.ga}</td>
            <td>${row.gd > 0 ? '+' : ''}${row.gd}</td>
            <td><strong>${row.pts}</strong></td>
          </tr>`;
        }

        html += '</tbody></table>';
        body.innerHTML = html;
        loadedStandings.add(groupId);
      } catch (_) {
        body.innerHTML = '<p style="text-align:center;color:var(--muted);padding:1rem;">Error al cargar. Reintentá.</p>';
      }
    }

    // Listen for standings toggle
    document.querySelectorAll('.standings').forEach(el => {
      el.addEventListener('toggle', () => {
        if (el.open) {
          loadStandings(el);
        }
      });
    });

    // If any standings are already open (e.g., auto-open from SSR), load immediately
    document.querySelectorAll('.standings[open]').forEach(el => {
      loadStandings(el);
    });

    // Initial poll + set interval
    // Process SSR-injected scores first so the first paint already shows real
    // scores (eliminates the "VS flash" before the first /api/live poll).
    processSSRScores();
    pollLive();
    // Also do an immediate client-side check for live matches by kickoff time
    const instantLive = getClientLiveMatches();
    if (instantLive.length > 0) {
      updateLiveFlag(instantLive.length, instantLive);
      populateLivePanel(instantLive);
    }
    setInterval(pollLive, LIVE_POLL_MS);

    // ---- Match detail panel (goals, cards, MVP) ----
    const detailTpl = document.getElementById('match-detail-tpl');

    function getWinnerTeam(home, away, hScore, aScore) {
      if (hScore === null || aScore === null) return null;
      if (hScore > aScore) return home;
      if (aScore > hScore) return away;
      return null; // draw
    }

    async function toggleMatchDetail(matchEl) {
      const matchId = matchEl.getAttribute('data-match-id');
      if (!matchId) return;

      // Check if detail already rendered
      let detailEl = matchEl.querySelector('.match-detail');

      if (detailEl) {
        const wasOpen = detailEl.classList.contains('is-open');
        detailEl.classList.toggle('is-open');
        if (wasOpen) {
          // Closed — stop auto-refreshing
          clearDetailRefresh();
        } else {
          // Reopened — restart auto-refresh if still live
          setupDetailRefresh(matchEl, matchId);
        }
        return;
      }

      // Create detail panel from template
      if (!detailTpl) return;
      const clone = detailTpl.content.cloneNode(true);
      detailEl = clone.firstElementChild || clone.querySelector('.match-detail');
      if (!detailEl) return;

      // Show loading
      const goalsList = detailEl.querySelector('[data-detail-goals]');
      const cardsList = detailEl.querySelector('[data-detail-cards]');
      const mvpEl = detailEl.querySelector('[data-detail-mvp]');
      if (goalsList) goalsList.innerHTML = '<span style="color:var(--muted)">Cargando…</span>';
      if (cardsList) cardsList.innerHTML = '';
      if (mvpEl) mvpEl.textContent = '';

      detailEl.classList.add('is-open');
      matchEl.appendChild(detailEl);

      try {
        const res = await fetch(`/api/match/${matchId}`);
        if (!res.ok) throw new Error('API error');
        const d = await res.json();
        renderDetailContent(detailEl, d, matchEl);
        // Refresh the score on the card with the latest data
        const home = matchEl.getAttribute('data-home');
        const away = matchEl.getAttribute('data-away');
        if (d.homeScore !== null && d.awayScore !== null) {
          updateMatchScore(d.id, home, away, d.homeScore, d.awayScore, d.status);
        }
        // Set up auto-refresh for live matches; no-op for finished
        setupDetailRefresh(matchEl, matchId);
      } catch (_) {
        if (goalsList) goalsList.innerHTML = '<span style="color:var(--muted)">Error al cargar</span>';
      }
    }

    // Delegated click: toggle match details on score click
    document.addEventListener('click', (e) => {
      const scoreEl = e.target.closest('.score--has');
      if (!scoreEl) return;
      const matchEl = scoreEl.closest('.match');
      if (!matchEl) return;
      // Don't trigger if clicking the VS modal area
      if (e.target.closest('.vs-modal')) return;
      e.stopPropagation();
      toggleMatchDetail(matchEl);
    });
  </script>
</Layout>
