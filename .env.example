# Copy this file to ".env" and paste your real token.
# Get a free token at https://www.football-data.org/client/register
# Free tier: 12 competitions (incl. FIFA World Cup, code WC), 10 requests/minute,
# scores delayed (near-live, not minute-by-minute).
# This token lives ONLY on the server (Vercel function). It is never sent to the browser.
FOOTBALL_DATA_TOKEN=your_token_here

# Optional: edge cache window for the /api/live endpoint, in seconds (default 60).
LIVE_CACHE_SECONDS=60
